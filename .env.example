HARBOR_VERSION=v2.15.0

# Public Harbor URL that users and Docker clients will hit.
HARBOR_HOSTNAME=harbor.example.com
HARBOR_EXTERNAL_URL=https://harbor.example.com

# Harbor listens on this internal HTTP port inside the Harbor frontend container.
HARBOR_HTTP_PORT=8080

# External Docker network and stable alias for reverse proxies such as Nginx Proxy Manager.
HARBOR_PROXY_NETWORK=proxy
HARBOR_PROXY_ALIAS=harbor-proxy

# Change these before any real deployment.
HARBOR_ADMIN_PASSWORD=change-this-admin-password
HARBOR_DB_PASSWORD=change-this-db-password

# Persistent host paths.
HARBOR_DATA_VOLUME=/path/to/harbor/data
HARBOR_LOG_LOCATION=/path/to/harbor/log

# Optional outbound proxy settings for Harbor components.
HARBOR_HTTP_PROXY=
HARBOR_HTTPS_PROXY=
HARBOR_NO_PROXY=127.0.0.1,localhost,core,registry,jobservice,db,redis,harbor-portal,proxy,harbor-proxy,harbor.example.com

# Docker logging driver for generated Harbor services. Use json-file or local to
# avoid reboot races against Harbor's internal syslog listener.
HARBOR_LOG_DRIVER=json-file

# Keep Trivy enabled by default. Set to true only when you intentionally pre-seed the DB offline.
HARBOR_TRIVY_SKIP_UPDATE=false

# Extra prepare flags. Harbor 2.15 still supports --with-trivy.
HARBOR_PREPARE_FLAGS=--with-trivy
